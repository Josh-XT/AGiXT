{
  "chain_name": "Chat with Code",
  "steps": [
    {
      "step": 1,
      "agent_name": "Claude",
      "prompt_type": "Command",
      "prompt": {
        "command_name": "Execute Shell Command",
        "command": "gh repo clone {repo_url} /tmp/repo && find /tmp/repo -type f -name '*.py' -o -name '*.js' -o -name '*.ts' -o -name '*.jsx' -o -name '*.tsx' -o -name '*.json' -o -name '*.yml' -o -name '*.yaml' -o -name '*.md' -o -name '*.rs' -o -name '*.go' | head -200 | while read f; do echo \"===== $f =====\"; head -100 \"$f\"; done",
        "conversation": "AGiXT Terminal"
      }
    },
    {
      "step": 2,
      "agent_name": "Claude",
      "prompt_type": "Prompt",
      "prompt": {
        "user_input": "{user_input}",
        "prompt_name": "Chat with Code",
        "prompt_category": "Default",
        "code": "{STEP1}",
        "shots": 1,
        "context_results": 0,
        "browse_links": false,
        "websearch": false,
        "websearch_depth": 0,
        "disable_memory": true,
        "inject_memories_from_collection_number": 0,
        "conversation_results": 0,
        "conversation": "AGiXT Terminal"
      }
    }
  ]
}
